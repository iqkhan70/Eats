@page "/admin/cleanup/audit-log"
@using TraditionalEats.WebApp.Services
@using Radzen
@using Radzen.Blazor
@inject AuthService AuthService
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Cleanup Audit Log - Admin - Kram</PageTitle>

<RadzenStack Gap="1.25rem" Style="padding: 1rem; max-width: 1100px; margin: 0 auto;">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
        <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/admin/cleanup"))" />
        <RadzenText TextStyle="TextStyle.H4">Cleanup Audit Log</RadzenText>
        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@LoadAuditLog" Disabled="@loading" />
    </RadzenStack>

    @if (!isAdmin)
    {
        <RadzenAlert Severity="AlertSeverity.Error">Admin access required.</RadzenAlert>
    }
    else if (loading)
    {
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
    }
    else if (auditLog == null || auditLog.Count == 0)
    {
        <RadzenText TextStyle="TextStyle.Body2">No cleanup runs recorded yet.</RadzenText>
    }
    else
    {
        <RadzenDataGrid Data="@auditLog" TItem="AuditLogEntry" AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="15"
            PagerHorizontalAlign="HorizontalAlign.Center" ExpandMode="DataGridExpandMode.Single" Style="width:100%;">
            <Columns>
                <RadzenDataGridExpandColumn TItem="AuditLogEntry" Width="50px" />
                <RadzenDataGridColumn TItem="AuditLogEntry" Property="RanAt" Title="When" FormatString="{0:yyyy-MM-dd HH:mm} UTC" Width="140px" />
                <RadzenDataGridColumn TItem="AuditLogEntry" Property="JobTypeName" Title="Job" Width="100px" />
                <RadzenDataGridColumn TItem="AuditLogEntry" Property="ParametersJson" Title="Params" Width="140px" />
                <RadzenDataGridColumn TItem="AuditLogEntry" Property="Status" Title="Status" Width="90px">
                    <Template Context="r">
                        <RadzenBadge Text="@r.Status" BadgeStyle="@(r.Status == "Success" ? BadgeStyle.Success : BadgeStyle.Danger)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AuditLogEntry" Property="RanByEmail" Title="By" Width="180px" />
            </Columns>
            <Template Context="entry">
                <div style="padding: 0.75rem 1rem; border-left: 3px solid var(--rz-primary); background: var(--rz-surface-50);">
                    <RadzenText TextStyle="TextStyle.Body2" Style="white-space: pre-wrap;">@FormatExpandedDetail(entry)</RadzenText>
                </div>
            </Template>
        </RadzenDataGrid>
    }
</RadzenStack>

@code {
    private bool isAdmin = false;
    private bool loading = true;
    private List<AuditLogEntry> auditLog = new();

    protected override async Task OnInitializedAsync()
    {
        isAdmin = await AuthService.IsAdminAsync();
        if (isAdmin) await LoadAuditLog();
    }

    private async Task LoadAuditLog()
    {
        loading = true;
        try
        {
            var resp = await Http.GetAsync("WebBff/admin/cleanup/audit-log?skip=0&take=100");
            if (resp.IsSuccessStatusCode)
                auditLog = await resp.Content.ReadFromJsonAsync<List<AuditLogEntry>>() ?? new();
            else
                auditLog = new();
        }
        catch { auditLog = new(); }
        finally { loading = false; StateHasChanged(); }
    }

    private static string FormatExpandedDetail(AuditLogEntry entry)
    {
        if (entry.Status == "Failed" && !string.IsNullOrEmpty(entry.ErrorMessage))
            return entry.ErrorMessage;

        if (string.IsNullOrWhiteSpace(entry.ResultJson)) return "—";

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(entry.ResultJson);
            var r = doc.RootElement;

            return entry.JobType switch
            {
                1 => FormatChatDetail(r),
                2 => FormatArchiveDetail(r),
                3 => FormatHistoryDetail(r, entry.ParametersJson),
                _ => entry.ResultJson
            };
        }
        catch { return entry.ResultJson; }
    }

    private static string FormatChatDetail(System.Text.Json.JsonElement r)
    {
        var orderMsg = GetInt(r, "deletedOrderMessages");
        var part = GetInt(r, "deletedParticipants");
        var vendorMsg = GetInt(r, "deletedVendorMessages");
        var conv = GetInt(r, "deletedConversations");
        var total = GetInt(r, "totalDeleted");
        if (total == 0) total = orderMsg + part + vendorMsg + conv;
        return "• Order chat messages deleted: " + orderMsg + "\n" +
            "• Order chat participants removed: " + part + "\n" +
            "• Vendor chat messages deleted: " + vendorMsg + "\n" +
            "• Vendor conversations removed: " + conv + "\n" +
            "• Total records removed: " + total;
    }

    private static string FormatArchiveDetail(System.Text.Json.JsonElement r)
    {
        var orders = GetInt(r, "archivedOrders");
        var payments = GetInt(r, "archivedPayments");
        return "• Orders moved to order_history: " + orders + "\n" +
            "• Payments moved to payment_history: " + payments + "\n" +
            "• Refunds tied to those orders were removed from the main tables";
    }

    private static string FormatHistoryDetail(System.Text.Json.JsonElement r, string? parametersJson)
    {
        var deleted = GetInt(r, "deletedCount");
        var scope = "records";
        if (!string.IsNullOrEmpty(parametersJson))
        {
            try
            {
                using var p = System.Text.Json.JsonDocument.Parse(parametersJson);
                if (p.RootElement.TryGetProperty("scope", out var s))
                    scope = s.GetString() == "order" ? "Order history" : "Payment history";
            }
            catch { }
        }
        return "• " + scope + " removed: " + deleted;
    }

    private static int GetInt(System.Text.Json.JsonElement el, string propertyName)
    {
        if (el.TryGetProperty(propertyName, out var p)) return p.GetInt32();
        var pascal = char.ToUpperInvariant(propertyName[0]) + propertyName[1..];
        if (el.TryGetProperty(pascal, out p)) return p.GetInt32();
        return 0;
    }

    private class AuditLogEntry
    {
        public long Id { get; set; }
        public int JobType { get; set; }
        public string? ParametersJson { get; set; }
        public string? ResultJson { get; set; }
        public DateTime RanAt { get; set; }
        public string? RanByUserId { get; set; }
        public string? RanByEmail { get; set; }
        public string Status { get; set; } = "";
        public string? ErrorMessage { get; set; }
        public string JobTypeName => JobType switch { 1 => "Chat", 2 => "Archive", 3 => "History", _ => "?" };
    }
}
