# Copy to .env and fill in your values.
# .env is gitignored – never commit secrets.

# Google Sign-In (required for "Continue with Google")
# Create BOTH OAuth clients at https://console.cloud.google.com/ – they must be DIFFERENT values:
#   - Web application: for Expo Go / redirect flow. Authorized redirect URIs must include:
#     https://auth.expo.io/@your-username/kram-mobile, com.kram.mobile:/oauthredirect,
#     and com.googleusercontent.apps.<each-android-client-prefix>:/oauthredirect (or you’ll see “custom scheme not allowed for Web client”).
#   - iOS: type "iOS", bundle ID com.kram.mobile. For TestFlight.
#   - Android: type "Android", package + SHA-1s. expo-auth-session redirect is com.<package>:/oauthredirect (see app.config.js schemes).
#     In GCP (since ~2023): each Android OAuth client → Advanced → enable “Custom URI scheme” for browser OAuth. Save; wait a few minutes.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Android: use two OAuth clients in GCP (different SHA-1s) — debug keystore vs release/upload keystore.
# At runtime: __DEV__ uses DEBUG first; production builds use RELEASE. Legacy: EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID = release only.
# If native Google Sign-In shows “Developer Error” after choosing an account: open the DEBUG Android OAuth client in GCP,
# ensure package com.kram.mobile and add SHA-1 from: keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android -keypass android
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID_DEBUG=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID_RELEASE=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Optional: true = Android uses EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID for the browser OAuth flow. Add com.kram.mobile:/oauthredirect to that Web client’s authorized redirect URIs in Google Cloud.
# EXPO_PUBLIC_GOOGLE_ANDROID_USE_WEB_CLIENT=

# Production Android (Play): https redirect on Mobile BFF — add this exact URL to the Web OAuth client. Avoids native “custom URI / Web client” errors.
# EXPO_PUBLIC_GOOGLE_ANDROID_BROWSER_REDIRECT_URI=https://www.kram.tech/api/MobileBff/oauth/google-callback

# Android push notifications (FCM / Expo push):
# Download google-services.json from Firebase for package com.kram.mobile and either:
# 1) put it at the project root as ./google-services.json, or
# 2) point to it explicitly with GOOGLE_SERVICES_JSON=./google-services.json
# GOOGLE_SERVICES_JSON=./google-services.json

# Expo Go + Google (browser): set your Expo account name so redirect can be https://auth.expo.io/@YOU/kram-mobile (avoids “custom scheme not allowed for Web client”). Or set full URL:
# EXPO_PUBLIC_EXPO_ACCOUNT=
# EXPO_PUBLIC_GOOGLE_AUTH_EXPO_REDIRECT_URI=https://auth.expo.io/@YOUR_EXPO_USERNAME/kram-mobile

# Support email for Help & Support mailto links (optional; defaults to support@kram.tech)
EXPO_PUBLIC_SUPPORT_EMAIL=
